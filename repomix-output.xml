    try {
      await api.post('/receipts', { receipt_no: receiptNo, warehouse_id: warehouseId, receipt_date: receiptDate, note, items: selectedItems });
      alert('Đã gửi yêu cầu nhập hàng!');
      setIsCreateOpen(false);
      setReceiptNo('');
      setSelectedItems([]);
      setNote('');
      fetchData();
