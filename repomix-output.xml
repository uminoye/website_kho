          <SectionCard title="Cảnh báo tồn kho thấp" subtitle="Các mặt hàng cần nhập bổ sung sớm theo từng kho" accent="#EF4444" action={<span style={{ fontSize: 12, color: '#64748B' }}>theo kho</span>}>
