                                <tbody
                                    style={{
                                        opacity: activeTab === 'tracking' ? (animateTrackingTable ? 1 : 0) : 1,
                                        transform: activeTab === 'tracking' ? (animateTrackingTable ? 'scale(1)' : 'scale(0.95)') : 'scale(1)',
                                        transformOrigin: 'top center',
